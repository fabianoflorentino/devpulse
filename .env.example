# DevPulse — local environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored; never commit real tokens.

# GitHub personal access token (classic or fine-grained).
# Required for private repos and higher API rate limits.
GITHUB_TOKEN=

# OpenAI API key — only needed when using --provider openai (default).
DEVPULSE_OPENAI_API_KEY=

# Ollama base URL — defaults to the ollama service in docker-compose.
# Override to point at a remote or host Ollama instance.
# DEVPULSE_OLLAMA_BASE_URL=http://localhost:11434
